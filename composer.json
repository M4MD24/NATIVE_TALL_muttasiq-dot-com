{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "goodm4ven/muttasiq",
    "type": "project",
    "description": "تطبيق يعين على الإسلام والالتزام باتساق ويسر بإذن الله",
    "keywords": [
        "laravel",
        "tallstack",
        "nativephp",
        "islam",
        "islamic",
        "thikr",
        "athkar"
    ],
    "license": "AGPL-3.0-only",
    "require": {
        "php": "^8.2",
        "blade-ui-kit/blade-heroicons": "^2.6",
        "blade-ui-kit/blade-icons": "^1.8",
        "filament/filament": "^5.0",
        "goodm4ven/blurred-image": "^1.1",
        "goodm4ven/nativephp-muttasiq-patches": "^1.0.0",
        "goodm4ven/tailwind-merge": "^1.1",
        "laravel/framework": "^12.0",
        "laravel/nightwatch": "^1.22",
        "laravel/tinker": "^2.10.1",
        "livewire/blaze": "^1.0",
        "livewire/livewire": "^4.0",
        "nativephp/mobile": "^3.0",
        "nativephp/mobile-browser": "^1.0",
        "predis/predis": "^3.4",
        "spatie/eloquent-sortable": "^4.5"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel-lang/lang": "^15.26",
        "laravel/boost": "^2.0",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.3",
        "pestphp/pest-plugin-browser": "^4.1",
        "pestphp/pest-plugin-faker": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-livewire": "^4.0"
    },
    "autoload": {
        "files": [
            "app/Services/Functions/custom.php",
            "app/Services/Functions/filament.php",
            "app/Services/Functions/generation.php",
            "app/Services/Functions/livewire.php",
            "app/Services/Functions/native.php",
            "app/Services/Functions/security.php",
            "app/Services/Functions/session.php",
            "app/Services/Functions/theme.php"
        ],
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate:fresh --seed --force",
            "npm install",
            "npm run build"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade",
            "@php artisan vendor:publish --tag=blurred-image-assets --force --ansi"
        ],
        "post-update-cmd": [
            "@php artisan boost:update --ansi",
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "optimize": [
            "@php artisan optimize:clear --ansi",
            "Composer\\Config::disableProcessTimeout",
            "@php artisan migrate"
        ],
        "dev": [
            "@optimize",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "format": [
            "npm run format:blade",
            "npm run format:prettier",
            "vendor/bin/pint"
        ],
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M",
        "lint": [
            "@format",
            "@analyse"
        ],
        "test": [
            "@optimize",
            ".scripts/testing/test.sh"
        ],
        "testparal": [
            "@optimize",
            ".scripts/testing/paral.sh"
        ],
        "testcov": [
            "@optimize",
            ".scripts/testing/cov.sh"
        ],
        "testbrowser": [
            "@optimize",
            "npx playwright install",
            ".scripts/testing/browser.sh"
        ],
        "testall": [
            "@optimize",
            "@testparal",
            "@testbrowser"
        ],
        "green": [
            "@optimize",
            "@php artisan app:verify-release-version",
            "@php artisan app:verify-local-plugin-switch",
            "@lint",
            "@testall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": {
    }
}
