APP_NAME="متسق"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://muttasiq.com

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
# LOG_STACK=single,nightwatch  # ! PROVIDE ONLY IN PRODUCTION AND REMOVE THE COMMENT AND THE LINE ABOVE
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=muttasiq
DB_USERNAME=root
DB_PASSWORD=password

SESSION_DRIVER=cookie
SESSION_LIFETIME=525600
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
CACHE_PREFIX=muttasiq_

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=muttasiq_

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_DEV_SERVER_URL=https://vite-muttasiq.dev.localhost

NIGHTWATCH_TOKEN="" # ! PROVIDE ONLY IN PRODUCTION AND REMOVE THE COMMENT
NIGHTWATCH_REQUEST_SAMPLE_RATE=0.1 # ! PROVIDE ONLY IN PRODUCTION AND REMOVE THE COMMENT

ADMIN_PATH="admin" # ! PROVIDE AND REMOVE THE COMMENT
ADMIN_NAME="Admin" # ! PROVIDE AND REMOVE THE COMMENT
ADMIN_EMAIL="admin@laravel.com" # ! PROVIDE AND REMOVE THE COMMENT
ADMIN_PASSWORD="password" # ! PROVIDE AND REMOVE THE COMMENT

NATIVEPHP_APP_ID="dev.goodm4ven.muttasiq" # ! PROVIDE AND REMOVE THE COMMENT
NATIVEPHP_APP_VERSION="1.0.0" # ! PROVIDE AND REMOVE THE COMMENT
NATIVEPHP_APP_VERSION_CODE="1" # ! PROVIDE AND REMOVE THE COMMENT

ANDROID_KEYSTORE_FILE=app-release-key.jks
ANDROID_KEYSTORE_PASSWORD="" # ! PROVIDE BEFORE RELEASE AND REMOVE THE COMMENT
ANDROID_KEY_ALIAS=app-key
ANDROID_KEY_PASSWORD="" # ! PROVIDE BEFORE RELEASE AND REMOVE THE COMMENT

IOS_DISTRIBUTION_CERTIFICATE_PATH=credentials/distribution.p12 # ! PROVIDE BEFORE RELEASE AND REMOVE THE COMMENT
IOS_DISTRIBUTION_CERTIFICATE_PASSWORD="" # ! PROVIDE BEFORE RELEASE AND REMOVE THE COMMENT
