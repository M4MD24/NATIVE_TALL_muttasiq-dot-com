APP_NAME="متسق"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://muttasiq.com

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=muttasiq
DB_USERNAME=root
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=525600
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_DEV_SERVER_URL=https://vite-muttasiq.dev.localhost

ADMIN_PATH="admin" # ! PROVIDE AND REMOVE THE COMMENT
ADMIN_NAME="Admin" # ! PROVIDE AND REMOVE THE COMMENT
ADMIN_EMAIL="admin@laravel.com" # ! PROVIDE AND REMOVE THE COMMENT
ADMIN_PASSWORD="password" # ! PROVIDE AND REMOVE THE COMMENT

NATIVEPHP_APP_ID="org.muttasiq.goodm4ven" # ! PROVIDE AND REMOVE THE COMMENT
NATIVEPHP_APP_VERSION="0.1.0" # ! PROVIDE AND REMOVE THE COMMENT
NATIVEPHP_APP_VERSION_CODE="1" # ! PROVIDE AND REMOVE THE COMMENT
